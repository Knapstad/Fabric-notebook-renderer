{
  "manifest_version": 3,
  "name": "Fabric Notebook Renderer",
  "version": "1.1.0",
  "author": "Bendik Knapstad",
  "description": "Renders Fabric notebook files on GitHub as cell cards with syntax highlighting and side-by-side diffs.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["lib/marked.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
